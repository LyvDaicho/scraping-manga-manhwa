# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment variables / secrets
.env
.env.*
!.env.example

# Packaging / build
build/
dist/
*.egg-info/
.eggs/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# IDE / editors
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

